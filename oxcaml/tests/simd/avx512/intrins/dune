; Internal-assembler variants: the same tests built with -internal-assembler,
; cross-checking the binary emitter's EVEX encodings against GAS.

(rule
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "amd64")
   (<> %{system} macosx)))
 (action
  (copy mem.ml mem_ia.ml)))

(executable
 (name mem_ia)
 (modules mem_ia)
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "amd64")
   (<> %{system} macosx)))
 (ocamlopt_flags
  (:standard -extension simd_alpha -favx512f -favx512vl -favx512dq -favx512bw
   -internal-assembler))
 (libraries stdlib_stable stdlib_upstream_compatible)
 (foreign_archives memstubs))

(rule
 (alias runtest)
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "amd64")
   (<> %{system} macosx)))
 (action
  (with-outputs-to
   mem_ia.out
   (run ./mem_ia.exe))))

