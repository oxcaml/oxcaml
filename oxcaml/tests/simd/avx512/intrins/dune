; AVX512 intrinsics tests: each emitted intrinsic is checked bit-for-bit against
; the real C intrinsic (the C compiler is the oracle). Enabled on amd64 non-macos
; in the main context, like the other AVX512 tests.

; The generated test sources are build-time rule targets (not checked in),
; regenerated from the same data that produces the selection code.
(rule
 (targets gen512.ml)
 (deps
  (:gen %{workspace_root}/tools/simdgen/simdgen.exe)
  (:csv %{workspace_root}/tools/simdgen/amd64/amd64.csv)
  (:xml %{workspace_root}/tools/simdgen/x86-intel.xml))
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "amd64")
   (<> %{system} macosx)))
 (action
  (with-stdout-to
   gen512.ml
   (run %{gen} intrins tests-ml %{csv} %{xml}))))

(rule
 (targets gen512_stubs.c)
 (deps
  (:gen %{workspace_root}/tools/simdgen/simdgen.exe)
  (:csv %{workspace_root}/tools/simdgen/amd64/amd64.csv)
  (:xml %{workspace_root}/tools/simdgen/x86-intel.xml))
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "amd64")
   (<> %{system} macosx)))
 (action
  (with-stdout-to
   gen512_stubs.c
   (run %{gen} intrins tests-c %{csv} %{xml}))))

; The C oracle for the generated tests must be compiled by clang: the host gcc
; (8.5) lacks many of the newer AVX512 intrinsic names.
(rule
 (targets libgen512stubs.a)
 (deps gen512_stubs.c (source_tree %{workspace_root}/runtime/caml))
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "amd64")
   (<> %{system} macosx)))
 (action
  (progn
   (run clang -c -O2 -mavx512f -mavx512vl -mavx512dq -mavx512bw -mavx512cd
     -I %{workspace_root}/runtime -o gen512_stubs.o gen512_stubs.c)
   (run ar rcs libgen512stubs.a gen512_stubs.o))))

(executable
 (name gen512)
 (modules gen512)
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "amd64")
   (<> %{system} macosx)))
 (ocamlopt_flags
  (:standard -extension simd_alpha -favx512f -favx512vl -favx512dq -favx512bw))
 (libraries stdlib_stable stdlib_upstream_compatible)
 (foreign_archives gen512stubs))

(rule
 (alias runtest)
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "amd64")
   (<> %{system} macosx)))
 (action
  (with-outputs-to
   gen512.out
   (run ./gen512.exe))))

(rule
 (alias runtest)
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "amd64")
   (<> %{system} macosx)))
 (action
  (diff empty.expected gen512.out)))

