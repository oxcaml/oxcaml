; Test disabling extensions required for 256/512 bit vectors.
;
; Run twice with each name-mangling scheme via the per-unit
; -name-mangling-scheme override (#5963), and compare against fixed
; per-scheme expected outputs.

(rule
 (alias runtest)
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "amd64")))
 (action
  (diff disabled256.flat.expected disabled256.flat.corrected)))

(rule
 (alias runtest)
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "amd64")))
 (action
  (diff disabled256.structured.expected disabled256.structured.corrected)))

(rule
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "amd64")))
 (targets disabled256.flat.corrected)
 (deps
  (:ml disabled256.ml))
 (action
  (setenv
   OCAMLRUNPARAM b=0
   (with-outputs-to
    disabled256.flat.corrected
    (pipe-outputs
     (with-accepted-exit-codes
      2
      (run
       %{bin:ocamlopt.opt}
       %{ml}
       -extension simd
       -color never
       -error-style short
       -fno-avx
       -name-mangling-scheme=flat))
     (run head -n 1))))))

(rule
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "amd64")))
 (targets disabled256.structured.corrected)
 (deps
  (:ml disabled256.ml))
 (action
  (setenv
   OCAMLRUNPARAM b=0
   (with-outputs-to
    disabled256.structured.corrected
    (pipe-outputs
     (with-accepted-exit-codes
      2
      (run
       %{bin:ocamlopt.opt}
       %{ml}
       -extension simd
       -color never
       -error-style short
       -fno-avx
       -name-mangling-scheme=structured))
     (run head -n 1))))))
