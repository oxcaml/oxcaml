no_barrier:
	movq	(%rax), %rax
	leaq	-1(%rax,%rax), %rax
	ret
load_across_load_fence:
	movq	(%rax), %rbx
	movl	$1, %edi
	lfence
	movq	(%rax), %rax
	leaq	-1(%rbx,%rax), %rax
	ret
load_across_memory_fence:
	movq	(%rax), %rbx
	movl	$1, %edi
	mfence
	movq	(%rax), %rax
	leaq	-1(%rbx,%rax), %rax
	ret
load_across_store_fence:
	movq	(%rax), %rax
	movl	$1, %ebx
	sfence
	leaq	-1(%rax,%rax), %rax
	ret
