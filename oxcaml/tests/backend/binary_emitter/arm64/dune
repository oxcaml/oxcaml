; Tests for ARM64 binary emitter
; Compares binary emitter output against system assembler output

(rule
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "arm64")))
 (targets test_basic.o test_basic.s (dir test_basic.binary-sections))
 (deps test_basic.ml)
 (action
  (run %{bin:ocamlopt.opt} -c -S -save-binary-sections %{deps})))

(rule
 (alias runtest)
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "arm64")))
 (deps
  test_basic.o
  (glob_files test_basic.binary-sections/*)
  compare_sections.sh)
 (action
  (run bash compare_sections.sh test_basic)))

; SIMD test - exercises NEON vector instructions
(rule
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "arm64")))
 (targets test_simd.o test_simd.s (dir test_simd.binary-sections))
 (deps test_simd.ml)
 (action
  (run %{bin:ocamlopt.opt} -extension simd_beta -c -S -save-binary-sections %{deps})))

(rule
 (alias runtest)
 (enabled_if
  (and
   (= %{context_name} "main")
   (= %{architecture} "arm64")))
 (deps
  test_simd.o
  (glob_files test_simd.binary-sections/*)
  compare_sections.sh)
 (action
  (run bash compare_sections.sh test_simd)))
