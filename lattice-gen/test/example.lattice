Locality = [
  Global < Local
]

Regionality = [
  Global < Regional < Local
]

locality_as_regionality : Locality -> Regionality = [
  Global -> Global;
  Local -> Local;
]

State = {
  loc : Regionality;
  fallback : Locality;
}

Projected_state = {
  region : Regionality;
  local : Locality;
}

state_to_projected : State -> Projected_state = {
  region = loc;
  local = fallback;
}
