Locality = [ Global < Local ]
Regionality = [ Global < Regional < Local ]
Uniqueness = [ Aliased > Unique ]
Linearity = [ Many < Once ]
Portability = [ Portable < Shareable < Nonportable ]
Contention = [ Contended > Shared > Uncontended ]
Forkable = [ Forkable < Unforkable ]
Yielding = [ Unyielding < Yielding ]
Staticity = [ Dynamic > Static ]
Statefulness = [ Stateless < Writing < Stateful; Stateless < Reading < Stateful ]
Visibility = [ Immutable > Read > Read_write; Immutable > Write > Read_write ]
Externality = [ External_ < External64 < Internal ]
Nullability = [ Non_null < Maybe_null ]
Separability = [ Non_float < Separable < Maybe_separable ]
Pointerness = [ Non_pointer < Maybe_pointer ]

Monadic = {
  uniqueness : Uniqueness;
  contention : Contention;
  visibility : Visibility;
  staticity : Staticity;
}

Comonadic = {
  linearity : Linearity;
  portability : Portability;
  forkable : Forkable;
  yielding : Yielding;
  statefulness : Statefulness;
}

Comonadic_with_locality = {
  areality : Locality;
  comonadic : Comonadic;
}

Comonadic_with_regionality = {
  areality : Regionality;
  comonadic : Comonadic;
}

Value = {
  comonadic : Comonadic_with_regionality;
  monadic : Monadic;
}

Alloc = {
  comonadic : Comonadic_with_locality;
  monadic : Monadic;
}

Scannable_axes = {
  externality : Externality;
  nullability : Nullability;
  separability : Separability;
  pointerness : Pointerness;
}

Kind_axes = {
  comonadic : Comonadic_with_locality;
  monadic : Monadic^op;
  scannable : Scannable_axes;
}

local_to_regional : Locality -> Regionality = [
  Global -> Global;
  Local -> Regional;
]

local_to_regional
  -| regional_to_local
  -| locality_as_regionality
  -| regional_to_global
  -| global_to_regional

regional_r2g : Regionality -> Regionality = [
  Global -> Global;
  Regional -> Global;
  Local -> Local;
]

linear_to_unique : Linearity -> Uniqueness^op = [
  Many -> Aliased;
  Once -> Unique;
]

linear_to_unique -| unique_to_linear

portable_to_contended : Portability -> Contention^op = [
  Portable -> Contended;
  Shareable -> Shared;
  Nonportable -> Uncontended;
]

portable_to_contended -| contended_to_portable

statefulness_to_visibility : Statefulness -> Visibility^op = [
  Stateless -> Immutable;
  Reading -> Read;
  Writing -> Write;
  Stateful -> Read_write;
]

statefulness_to_visibility -| visibility_to_statefulness

comonadic_local_to_regional : Comonadic_with_locality -> Comonadic_with_regionality = {
  areality = local_to_regional(areality);
  comonadic = comonadic;
}

comonadic_local_to_regional
  -| comonadic_regional_to_local
  -| comonadic_locality_as_regionality
  -| comonadic_regional_to_global
  -| comonadic_global_to_regional

comonadic_r2g : Comonadic_with_regionality -> Comonadic_with_regionality = {
  areality = regional_r2g(areality);
  comonadic = comonadic;
}

comonadic_to_monadic_min : Comonadic -> Monadic^op = {
  uniqueness = linear_to_unique(linearity);
  contention = portable_to_contended(portability);
  visibility = statefulness_to_visibility(statefulness);
  staticity = min;
}

comonadic_to_monadic_min -| monadic_to_comonadic_max

monadic_to_comonadic_min : Monadic^op -> Comonadic = {
  linearity = unique_to_linear(uniqueness);
  portability = contended_to_portable(contention);
  statefulness = visibility_to_statefulness(visibility);
  forkable = min;
  yielding = min;
}

monadic_to_comonadic_min -| comonadic_to_monadic_max

alloc_to_value_l2r : Alloc -> Value = {
  comonadic = comonadic_local_to_regional(comonadic);
  monadic = monadic;
}

alloc_to_value_l2r
  -| value_to_alloc_r2l
  -| alloc_as_value
  -| value_to_alloc_r2g

value_r2g : Value -> Value = {
  comonadic = comonadic_r2g(comonadic);
  monadic = monadic;
}
