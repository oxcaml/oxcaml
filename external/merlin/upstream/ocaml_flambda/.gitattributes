# Files from the corresponding compiler directories that we do not import.
# Setting the merlin-exclude attribute excludes a file; unsetting it with
# "-merlin-exclude" re-includes a file matched by an earlier pattern.

# Formatter configuration, build files and documentation are never imported,
# from any directory.
.ocamlformat* merlin-exclude
dune merlin-exclude
*.md merlin-exclude
*.adoc merlin-exclude

file_formats/cfg_format.ml* merlin-exclude
file_formats/cmj_format.mli merlin-exclude

lambda/** merlin-exclude
lambda/mixed_product_bytes.ml* -merlin-exclude

typing/cmt2annot.mli merlin-exclude

utils/arrayset.ml* merlin-exclude
utils/config.*.ml* merlin-exclude
utils/debug.ml* merlin-exclude
utils/doubly_linked_list.ml* merlin-exclude
utils/file_sections.ml* merlin-exclude
utils/linkage_name.ml* merlin-exclude
utils/lru.ml* merlin-exclude
utils/priority_queue.ml* merlin-exclude
utils/runtimetags.ml* merlin-exclude
utils/structured_mangling.ml* merlin-exclude
utils/symbol.ml* merlin-exclude
utils/target_system.ml* merlin-exclude
